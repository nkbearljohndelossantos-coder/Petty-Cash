# Force HTTP/1.1 to avoid ERR_HTTP2_PROTOCOL_ERROR on some servers
<IfModule mod_protocols.c>
    Protocols http/1.1
</IfModule>

# Correct MIME types for ES modules
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
</IfModule>

# Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Force browser and server cache bust for HTML files
<FilesMatch "\.(html|htm)$">
    FileETag None
    <IfModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
        Header set Surrogate-Control "no-store"
        Header set X-LiteSpeed-Cache-Control "no-cache"
    </IfModule>
</FilesMatch>

# Cache static assets aggressively since they have hashed names in production
<IfModule mod_headers.c>
    <FilesMatch "\.(js|mjs|css|png|jpg|jpeg|gif|ico|svg|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# SPA fallback — NEVER rewrite missing /assets/ requests to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^assets/ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

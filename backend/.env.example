PORT=5000
NODE_ENV=development

# Database Credentials (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_db_name

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=24h

# Redis Configuration (Optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Email Configuration – Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-full-email@yourdomain.com
SMTP_PASS=your-mailbox-password
EMAIL_FROM="NKB Petty Cash" <your-full-email@yourdomain.com>
APP_NAME=NKB Petty Cash

# App Config
FRONTEND_URL=http://localhost:5173

# Canteen employee lookup (barcode scanner)
CANTEEN_API_URL=https://canteen.nkbmanufacturing.com/api/integration/employees
CANTEEN_API_KEY=your_canteen_integration_api_key
